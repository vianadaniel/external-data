### SPC via API externals (SPC_USERNAME/SPC_PASSWORD; em 401/403 tenta SPC_*_BACKUP)
# Suba o servidor: npm run start:dev (porta em PORT, ex.: 3002)
@baseUrl = http://localhost:3003
@cnpj = 04639628000192
@cpf = 06604890660

### Consulta produção (body igual ao da API SPC)
POST {{baseUrl}}/externals/spc/consulta-producao
Content-Type: application/json

{
  "codigoProduto": "325",
  "tipoConsumidor": "J",
  "documentoConsumidor": "{{cnpj}}",
  "codigoInsumoOpcional": [78]
}

### Pessoa jurídica (atalho — default codigoProduto 695)
POST {{baseUrl}}/externals/spc/pessoa-juridica
Content-Type: application/json

{
  "cnpj": "{{cnpj}}",
  "codigoProduto": "325",
  "insumos": [78]
}

### Pessoa física (atalho — default codigoProduto 695)
POST {{baseUrl}}/externals/spc/pessoa-fisica
Content-Type: application/json

{
  "cpf": "{{cpf}}",
  "codigoProduto": "695",
  "insumos": []
}
