### Registro Rural via API externals (API_KEY_RR no .env)
# Suba o servidor: npm run start:dev (porta em PORT, ex.: 3003)
@baseUrl = http://localhost:3003
@cpfcnpj = 06604890660

### INCRA — busca por CPF/CNPJ
POST {{baseUrl}}/externals/rr/incra
Content-Type: application/json

{
  "cpfcnpj": "{{cpfcnpj}}"
}

### CAR — busca por CPF/CNPJ
